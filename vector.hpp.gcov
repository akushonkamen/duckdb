        -:  719:
        -:  720:struct UnionVector {
        -:  721:	// Unions are stored as structs, but the first child is always the "tag"
        -:  722:	// vector, specifying the currently selected member for that row.
        -:  723:	// The remaining children are the members of the union.
        -:  724:	// INVARIANTS:
        -:  725:	//	1.	Only one member vector (the one "selected" by the tag) can be
        -:  726:	//		non-NULL in each row.
        -:  727:	//
        -:  728:	//	2.	The validity of the tag vector always matches the validity of the
        -:  729:	//		union vector itself.
        -:  730:	//
        -:  731:	//  3.  A valid union cannot have a NULL tag, but the selected member can
        -:  732:	//  	be NULL. therefore, there is a difference between a union that "is"
        -:  733:	//  	NULL and a union that "holds" a NULL. The latter still has a valid
        -:  734:	//  	tag.
        -:  735:	//
        -:  736:	//	4.	For each tag in the tag vector, 0 <= tag < |members|
        -:  737:
        -:  738:	//! Get the tag vector of a union vector
        -:  739:	DUCKDB_API static const Vector &GetTags(const Vector &v);
        -:  740:	DUCKDB_API static Vector &GetTags(Vector &v);
        -:  741:
        -:  742:	//! Try to get the tag at the specific flat index of the union vector. Returns false if the tag is NULL.
        -:  743:	//! This will handle and map the index properly for constant and dictionary vectors internally.
        -:  744:	DUCKDB_API static bool TryGetTag(const Vector &vector, idx_t index, union_tag_t &tag);
        -:  745:
        -:  746:	//! Get the member vector of a union vector by index
        -:  747:	DUCKDB_API static const Vector &GetMember(const Vector &vector, idx_t member_index);
        -:  748:	DUCKDB_API static Vector &GetMember(Vector &vector, idx_t member_index);
        -:  749:
        -:  750:	//! Set every entry in the UnionVector to a specific member.
        -:  751:	//! This is useful to set the entire vector to a single member, e.g. when "creating"
        -:  752:	//! a union to return in a function, when you only have one alternative to return.
        -:  753:	//! if 'keep_tags_for_null' is false, the tags will be set to NULL where the member is NULL.
        -:  754:	//! (the validity of the tag vector will match the selected member vector)
        -:  755:	//! otherwise, they are all set to the 'tag'.
        -:  756:	//! This will also handle invalidation of the non-selected members
        -:  757:	DUCKDB_API static void SetToMember(Vector &vector, union_tag_t tag, Vector &member_vector, idx_t count,
        -:  758:	                                   bool keep_tags_for_null);
        -:  759:
        -:  760:	DUCKDB_API static UnionInvalidReason
        -:  761:	CheckUnionValidity(Vector &vector, idx_t count,
        -:  762:	                   const SelectionVector &sel = *FlatVector::IncrementalSelectionVector());
        -:  763:};
