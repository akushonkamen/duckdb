        -:  250://! Returns whether or not two reference wrappers refer to the same object
        -:  251:template<class T>
        -:  252:bool RefersToSameObject(const reference<T> &a, const reference<T> &b) {
        -:  253:	return &a.get() == &b.get();
        -:  254:}
        -:  255:
        -:  256:template<class T>
        -:  257:bool RefersToSameObject(const T &a, const T &b) {
        -:  258:	return &a == &b;
        -:  259:}
