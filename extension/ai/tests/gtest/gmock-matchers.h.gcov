        -:  826:  // RefMatcher() takes a T& instead of const T&, as we want the
        -:  827:  // compiler to catch using Ref(const_value) as a matcher for a
        -:  828:  // non-const reference.
        -:  829:  explicit RefMatcher(T& x) : object_(x) {}  // NOLINT
