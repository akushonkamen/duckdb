        -:  279:
        -:  280:// MSVC warning C5046 is new as of VS2017 version 15.8.
        -:  281:#if defined(_MSC_VER) && _MSC_VER >= 1915
        -:  282:#define GMOCK_MAYBE_5046_ 5046
        -:  283:#else
        -:  284:#define GMOCK_MAYBE_5046_
