        -:  891:      return impl_.template Perform<Result>(args);
        -:  892:    }
        -:  893:
        -:  894:   private:
        -:  895:    Impl impl_;
        -:  896:  };
        -:  897:
        -:  898:  Impl impl_;
        -:  899:};
