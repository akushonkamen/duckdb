        -:  185:    bool,
        -:  186:    // clang-format off
        -:  187:      // Converting from bool is always lossless
        -:  188:      (kFromKind == kBool) ? true
        -:  189:      // Converting between any other type kinds will be lossy if the type
        -:  190:      // kinds are not the same.
