        -:  159:
        -:  160:	// Retry 2: 200ms ± 40ms
        2:  161:	EXPECT_CALL(*mock_random, GetRandomInt(-40, 40))
        1:  162:		.WillOnce(Return(-20));
        1:  163:	EXPECT_CALL(*mock_clock, SleepMs(180));  // 200 - 20
        -:  164:
        -:  165:	// Retry 3: 400ms ± 80ms
        2:  166:	EXPECT_CALL(*mock_random, GetRandomInt(-80, 80))
        1:  167:		.WillOnce(Return(50));
        1:  168:	EXPECT_CALL(*mock_clock, SleepMs(450));  // 400 + 50
        -:  169:
